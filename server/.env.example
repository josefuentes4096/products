# Copia este fichero a server/.env y completa los valores.
# Lo lee docker compose (server/docker-compose.yml) y se inyecta en la app.

# ----------------------------------------------------------------------------
# MySQL (desarrollo local con docker compose)
# ----------------------------------------------------------------------------
# docker compose levanta un contenedor mysql:8 usando DB_PASSWORD como password
# de root, crea la base "products" y la app se conecta a ella como root via
# DB_URL=jdbc:mysql://mysql:3306/products (definido en docker-compose.yml).
#
# Limitacion del contenedor MySQL oficial: MYSQL_USER no puede ser "root", asi
# que docker compose siempre conecta como root. Si quieres un usuario distinto,
# anade MYSQL_USER=<usuario> a docker-compose.yml.
DB_USERNAME=root
DB_PASSWORD=root

# Solo necesario si arrancas la app sin docker compose y tu MySQL no esta en
# localhost:3306/products. Para TiDB Serverless en produccion, usa el JDBC
# completo con sslMode=VERIFY_IDENTITY:
# DB_URL=jdbc:mysql://gateway01.<region>.prod.aws.tidbcloud.com:4000/products?sslMode=VERIFY_IDENTITY&enabledTLSProtocols=TLSv1.2,TLSv1.3

# ----------------------------------------------------------------------------
# CORS — origenes permitidos del frontend (coma-separados)
# ----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ----------------------------------------------------------------------------
# Logging de SQL de Hibernate (true/false). Mantener en false en produccion.
# ----------------------------------------------------------------------------
# SHOW_SQL=false
