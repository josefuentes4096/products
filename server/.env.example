# Copia este fichero a server/.env y completa los valores.
# Lo lee docker compose (server/docker-compose.yml) y se inyecta en la app.

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
# Para desarrollo local con docker compose, basta con DB_USERNAME y DB_PASSWORD:
# docker compose levanta el contenedor postgres con esas credenciales y la app
# se conecta vía DB_URL=jdbc:postgresql://postgres:5432/products (definido en
# docker-compose.yml).
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Sólo necesario si arrancas la app sin docker compose y tu Postgres no está en
# localhost:5432/products. Para Neon en producción, usa el JDBC completo con
# sslmode=require y channelBinding=require:
# DB_URL=jdbc:postgresql://ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channelBinding=require

# ----------------------------------------------------------------------------
# CORS — orígenes permitidos del frontend (coma-separados)
# ----------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ----------------------------------------------------------------------------
# Logging de SQL de Hibernate (true/false). Mantener en false en producción.
# ----------------------------------------------------------------------------
# SHOW_SQL=false
